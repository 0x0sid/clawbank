# OKX CEX API (required for live trading)
OKX_API_KEY=your-okx-api-key
OKX_SECRET_KEY=your-okx-secret-key
OKX_PASSPHRASE=your-okx-passphrase

# OKX OnchainOS (required for DeFi)
OKX_ONCHAIN_API_KEY=your-onchain-api-key

# On-chain treasury (required for contract interactions)
BANKER_KEY=your-banker-private-key
TREASURY_ADDRESS=your-deployed-contract-address
TREASURY_RPC_URL=https://sepolia.base.org

# Dashboard
DASHBOARD_PORT=3030

# Logging (trace, debug, info, warn, error)
RUST_LOG=info

# Credit system
MAX_CREDIT_USD=100000
RECALL_CHECK_INTERVAL_SECS=30

# OpenRouter (for agent supervisor LLM)
OPENROUTER_API_KEY=your-openrouter-api-key
OPENROUTER_MODEL=nvidia/nemotron-3-super-120b-a12b:free
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
